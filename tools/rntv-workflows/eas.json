{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "android": {
        "resourceClass": "large",
        "image": "latest"
      },
      "ios": {
        "resourceClass": "large",
        "image": "latest"
      },
      "withoutCredentials": true,
      "distribution": "internal",
      "node": "22.14.0"
    },
    "android-artifacts-main": {
      "extends": "base",
      "android": {
        "config": "build-android-artifacts.yml"
      }
    },
    "android-artifacts": {
      "extends": "android-artifacts-main",
      "env": {
        "RNTV_RELEASE_BUILD": "1"
      }
    },
    "rntester-android-main": {
      "extends": "base",
      "android": {
        "config": "build-rntester-android.yml"
      }
    },
    "rntester-android": {
      "extends": "rntester-android-main",
      "env": {
        "RNTV_RELEASE_BUILD": "1"
      }
    },
    "apple-artifacts-main": {
      "extends": "base",
      "ios": {
        "config": "build-apple-artifacts.yml"
      }
    },
    "apple-artifacts": {
      "extends": "rncore-main",
      "env": {
        "RNTV_RELEASE_BUILD": "1"
      }
    },
    "rntester-apple-release-main": {
      "extends": "base",
      "env": {
        "RNTESTER_CONFIGURATION": "release"
      },
      "ios": {
        "config": "build-rntester-apple.yml"
      }
    },
    "rntester-apple-release": {
      "extends": "rntester-apple-release-main",
      "env": {
        "RNTV_RELEASE_BUILD": "1"
      }
    },
    "rntester-apple-debug-main": {
      "extends": "base",
      "env": {
        "RNTESTER_CONFIGURATION": "debug"
      },
      "ios": {
        "config": "build-rntester-apple.yml"
      }
    },
    "rntester-apple-debug": {
      "extends": "rntester-apple-debug-main",
      "env": {
        "RNTV_RELEASE_BUILD": "1"
      }
    },
    "npm-images-main": {
      "extends": "base",
      "android": {
        "config": "build-npm-images.yml"
      }
    },
    "npm-images": {
      "extends": "npm-images-main",
      "env": {
        "RNTV_RELEASE_BUILD": "1"
      }
    }
  }
}
